{
  "name": "print-core-api",
  "version": "1.0.0",
  "description": "Production-ready backend API for print SaaS platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate && ./node_modules/.bin/tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "lint": "./node_modules/.bin/tsc --noEmit",
    "prisma:push": "prisma db push",
    "seed:dev": "tsx src/bootstrap/seed-demo-run.ts"
  },
  "keywords": [
    "express",
    "prisma",
    "typescript",
    "postgresql"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "zod": "^3.24.2",
    "typescript": "^5.8.2",
    "prisma": "^6.6.0",
    "@types/node": "^22.13.10",
    "@types/express": "^5.0.1",
    "@types/cors": "^2.8.17"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "prisma": "^6.6.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2",
    "tsx": "^4.19.2"
  }
}