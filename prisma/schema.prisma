generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id              String              @id @default(cuid())
  name            String
  slug            String              @unique
  description     String?
  creationMethod  String              @default("blank")
  productType     String
  categoryId      String?
  vendorId        String              @default("")
  hotFolder       String              @default("")
  pdfFileUrl      String?
  cmsPageLink     String              @default("")
  previewUrl      String              @default("")
  thumbnail       String              @default("")
  sortOrder       Int                 @default(0)
  pages           Int                 @default(1)
  units           String              @default("mm")
  width           Float               @default(0)
  height          Float               @default(0)
  bleed           Float               @default(0)
  isGlobal        Boolean             @default(false)
  published       Boolean             @default(false)
  storefrontIds   Json?
  lastSavedAt     DateTime?
  productNumbers  Json?
  templateDefaults Json?
  templateSetup   Json?
  templateAssets  Json?
  priceMapping    Json?
  comments        Json?
  internalNotes   String              @default("")
  inventory       Json?
  relatedProducts Json?
  attributes      Json?
  alternateViews  Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  channels        ProductChannel[]
  productTags     ProductTagMap[]
  collectionItems CollectionProduct[]
}

model Channel {
  id            String           @id @default(cuid())
  name          String
  slug          String           @unique
  domain        String?          @unique
  status        String
  themeId       String?
  currency      String
  locale        String
  isHeadless    Boolean          @default(false)
  publicApiKey  String           @unique
  privateApiKey String           @unique
  createdAt     DateTime         @default(now())
  theme         Theme?           @relation(fields: [themeId], references: [id])
  products      ProductChannel[]

  @@index([status])
}

model Theme {
  id          String    @id @default(cuid())
  name        String
  description String?
  version     String
  author      String
  createdAt   DateTime  @default(now())
  channels    Channel[]
}

model Category {
  id                 String                @id @default(cuid())
  name               String
  description        String                @default("")
  parentId           String?
  parent             Category?             @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children           Category[]            @relation("CategoryHierarchy")
  pricingId          String                @default("")
  attributeSetId     String                @default("")
  published          Boolean               @default(true)
  thumbnail          String                @default("")
  friendlyUrl        String                @unique
  sortOrder          Int                   @default(0)
  accuZipConfig      String                @default("")
  useAlternateMaster Boolean               @default(false)
  canBrowse          Boolean               @default(true)
  canUpload          Boolean               @default(false)
  canUploadLater     Boolean               @default(false)
  canCreate          Boolean               @default(true)
  canCustom          Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  categoryTags       CategoryTagMap[]
  collections        CollectionCategory[]

  @@index([parentId])
  @@index([published])
}

model CategoryTag {
  id          String           @id @default(cuid())
  label       String           @unique
  createdAt   DateTime         @default(now())
  categories  CategoryTagMap[]
}

model CategoryTagMap {
  categoryId String
  tagId      String
  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tag        CategoryTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([categoryId, tagId])
}

model Tag {
  id         String          @id @default(cuid())
  name       String
  parentId   String?
  parent     Tag?            @relation("TagHierarchy", fields: [parentId], references: [id])
  children   Tag[]           @relation("TagHierarchy")
  friendlyUrl String         @unique
  published  Boolean         @default(false)
  sidebar    Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  productTags ProductTagMap[]

  @@index([parentId])
}

model ProductTagMap {
  productId String
  tagId     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

model Collection {
  id         String               @id @default(cuid())
  title      String               @unique
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  products   CollectionProduct[]
  categories CollectionCategory[]
}

model CollectionProduct {
  collectionId String
  productId    String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
}

model CollectionCategory {
  collectionId String
  categoryId   String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([collectionId, categoryId])
}

model ProductChannel {
  productId String
  channelId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([productId, channelId])
  @@index([channelId])
}


model Tenant {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  status           String         @default("active")
  planName         String         @default("Starter")
  storefrontsUsed  Int            @default(1)
  storefrontsLimit Int            @default(1)
  adminUsersUsed   Int            @default(1)
  adminUsersLimit  Int            @default(3)
  storageUsedGb    Int            @default(0)
  storageLimitGb   Int            @default(10)
  nextBillingDate  DateTime?
  defaultSubdomain String?
  primaryDomain    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  domains          TenantDomain[]
  orders           Order[]
}

model TenantDomain {
  id                 String   @id @default(cuid())
  tenantId           String
  hostname           String   @unique
  type               String
  isPrimary          Boolean  @default(false)
  verificationStatus String   @default("pending")
  sslStatus          String   @default("pending")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Order {
  id            String      @id @default(cuid())
  tenantId      String?
  orderNumber   String      @unique
  customerName  String
  email         String?
  status        String      @default("artwork-review")
  totalMinor    Int         @default(0)
  currency      String      @default("GBP")
  submittedAt   DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tenant        Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  artworks      Artwork[]

  @@index([tenantId])
}


model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productName   String
  quantity      Int      @default(1)
  unitPriceMinor Int     @default(0)
  lineTotalMinor Int     @default(0)
  variantLabel  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Artwork {
  id             String   @id @default(cuid())
  orderId         String?
  orderReference  String?
  customerEmail   String?
  fileName        String
  fileType        String
  note            String?
  status          String   @default("pending-review")
  source          String   @default("api")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order           Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([orderReference])
}

model Material {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  gsm         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model Finish {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model OptionSet {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
